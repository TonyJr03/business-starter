---
import MainLayout from '@/layouts/MainLayout.astro';
import Section from '@/components/ui/Section.astro';
import SectionHeader from '@/components/common/SectionHeader.astro';
import Card from '@/components/ui/Card.astro';
import Input from '@/components/ui/Input.astro';
import Textarea from '@/components/ui/Textarea.astro';
import Button from '@/components/ui/Button.astro';
import OpeningHoursSection from '@/components/sections/OpeningHoursSection.astro';
import { globalConfig } from '@/config';
import { getWhatsAppUrl } from '@/lib/whatsapp';

const { identity, location, contact, hours, social } = globalConfig;
const name = identity.name;

const whatsappUrl = getWhatsAppUrl(`Hola ${name}, quisiera ponerme en contacto.`);
---

<MainLayout
  title="Contacto"
  description={`Contáctanos por WhatsApp o visítanos en ${location.street ?? location.city}, ${location.city}.`}
>
  <!-- ── Encabezado ──────────────────────────────────────────────────────── -->
  <Section bg="secondary" size="md">
    <div class="max-w-2xl mx-auto text-center">
      <h1 class="text-4xl font-bold tracking-tight mb-3" style="color: var(--color-primary);">
        Contáctanos
      </h1>
      <p class="text-lg" style="color: var(--color-text-muted);">
        Estamos disponibles para atenderte. La forma más rápida es por WhatsApp.
      </p>
    </div>
  </Section>

  <!-- ── CTA WhatsApp prominente ─────────────────────────────────────────── -->
  {contact.whatsapp && (
    <Section bg="default" size="sm">
      <div class="max-w-xl mx-auto">
        <a
          href={whatsappUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-4 rounded-2xl p-5 border transition-shadow hover:shadow-md focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2"
          style="
            background-color: var(--color-surface);
            border-color: var(--color-border);
            focus-visible:ring-color: #25D366;
          "
          aria-label="Escribirnos por WhatsApp"
        >
          {/*Ícono WhatsApp */}
          <span
            class="flex items-center justify-center size-14 rounded-full shrink-0"
            style="background-color: #25D366;"
            aria-hidden="true"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="white" class="size-7">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
              <path d="M12 0C5.373 0 0 5.373 0 12c0 2.123.554 4.118 1.528 5.855L.057 23.428a.75.75 0 0 0 .915.915l5.573-1.471A11.943 11.943 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.75a9.693 9.693 0 0 1-4.953-1.36l-.355-.212-3.683.972.985-3.595-.231-.37A9.694 9.694 0 0 1 2.25 12C2.25 6.615 6.615 2.25 12 2.25S21.75 6.615 21.75 12 17.385 21.75 12 21.75z"/>
            </svg>
          </span>
          {/* Texto */}
          <div class="flex-1 min-w-0">
            <p class="font-semibold" style="color: var(--color-text);">Escríbenos por WhatsApp</p>
            <p class="text-sm truncate" style="color: var(--color-text-muted);">
              {contact.whatsapp} · Respuesta rápida
            </p>
          </div>
          {/* Flecha */}
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="size-5 shrink-0"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            style="color: var(--color-text-subtle);"
            aria-hidden="true"
          >
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>
    </Section>
  )}

  <!-- ── Datos de contacto + Formulario ─────────────────────────────────── -->
  <Section bg="surface" size="md">
    <div class="max-w-5xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-12">

      <!-- Columna izquierda: datos ──────────────────────────────────────── -->
      <div class="space-y-8">
        <SectionHeader title="Información de contacto" align="left" />

        <ul class="space-y-5" style="color: var(--color-text);">

          <!-- Dirección -->
          <li class="flex items-start gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="size-5 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color: var(--color-primary);" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span class="leading-relaxed">
              {location.street && <>{location.street}<br /></>}
              {location.municipality ? `${location.municipality}, ` : ''}{location.city}
              {location.country ? `, ${location.country}` : ''}
            </span>
          </li>

          <!-- Teléfono -->
          {contact.phone && (
            <li class="flex items-center gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="size-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color: var(--color-primary);" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              <a href={`tel:${contact.phone}`} class="hover:underline">{contact.phone}</a>
            </li>
          )}

          <!-- Email -->
          {contact.email && (
            <li class="flex items-center gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="size-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color: var(--color-primary);" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              <a href={`mailto:${contact.email}`} class="hover:underline">{contact.email}</a>
            </li>
          )}

        </ul>

        <!-- Redes sociales -->
        {(social.instagram || social.facebook) && (
          <div class="space-y-3">
            <p class="text-sm font-semibold" style="color: var(--color-text);">Síguenos</p>
            <div class="flex gap-3 flex-wrap">
              {social.instagram && (
                <a
                  href={social.instagram}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-2 text-sm px-4 py-2 rounded-full border border-(--color-border) text-(--color-text-muted) transition-colors hover:bg-[#E1306C] hover:border-[#E1306C] hover:text-white"
                  aria-label="Instagram"
                >
                  Instagram
                </a>
              )}
              {social.facebook && (
                <a
                  href={social.facebook}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-2 text-sm px-4 py-2 rounded-full border border-(--color-border) text-(--color-text-muted) transition-colors hover:bg-[#1877F2] hover:border-[#1877F2] hover:text-white"
                  aria-label="Facebook"
                >
                  Facebook
                </a>
              )}
            </div>
          </div>
        )}
      </div>

      <!-- Columna derecha: formulario ──────────────────────────────────── -->
      <div>
        <Card variant="default">
          <div class="p-6 sm:p-8">
            <h2 class="text-xl font-bold mb-6" style="color: var(--color-text);">
              Déjanos un mensaje
            </h2>

            <!--
              Formulario visual sin backend.
              action / method se conectarán cuando el backend esté listo.
              Por ahora el botón muestra el estado visual pero no envía.
            -->
            <form
              novalidate
              class="space-y-5"
              aria-label="Formulario de contacto"
            >
              <Input
                id="contact-name"
                name="name"
                label="Nombre"
                type="text"
                placeholder="Tu nombre completo"
                required
                autocomplete="name"
              />

              <Input
                id="contact-phone"
                name="phone"
                label="Teléfono / WhatsApp"
                type="tel"
                placeholder="+53 5 000 0000"
                required
                autocomplete="tel"
                helperText="Usaremos este número para responderte."
              />

              <Input
                id="contact-email"
                name="email"
                label="Correo electrónico"
                type="email"
                placeholder="tu@correo.com"
                autocomplete="email"
              />

              <Textarea
                id="contact-message"
                name="message"
                label="Mensaje"
                placeholder="¿En qué podemos ayudarte?"
                required
                rows={5}
              />

              <div class="pt-1 flex flex-col sm:flex-row gap-3">
                <Button type="submit" variant="primary" size="md" class="w-full sm:w-auto">
                  Enviar mensaje
                </Button>
                {contact.whatsapp && (
                  <a
                    href={whatsappUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center justify-center gap-2 rounded-full px-6 py-3 text-base font-semibold text-white transition-colors hover:opacity-90 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 w-full sm:w-auto"
                    style="background-color: #25D366;"
                  >
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-5 shrink-0" aria-hidden="true">
                      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
                      <path d="M12 0C5.373 0 0 5.373 0 12c0 2.123.554 4.118 1.528 5.855L.057 23.428a.75.75 0 0 0 .915.915l5.573-1.471A11.943 11.943 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.75a9.693 9.693 0 0 1-4.953-1.36l-.355-.212-3.683.972.985-3.595-.231-.37A9.694 9.694 0 0 1 2.25 12C2.25 6.615 6.615 2.25 12 2.25S21.75 6.615 21.75 12 17.385 21.75 12 21.75z"/>
                    </svg>
                    WhatsApp
                  </a>
                )}
              </div>

              <p class="text-xs" style="color: var(--color-text-subtle);">
                * Los campos marcados son obligatorios. Tu información no será compartida con terceros.
              </p>
            </form>

          </div>
        </Card>
      </div>

    </div>
  </Section>

  <!-- ── Horarios ────────────────────────────────────────────────────────── -->
  {hours.length > 0 && (
    <OpeningHoursSection
      hours={hours}
      title="Horarios de atención"
      bg="default"
      size="md"
    />
  )}

</MainLayout>
