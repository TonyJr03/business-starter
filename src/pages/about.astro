---
import MainLayout from '@/layouts/MainLayout.astro';
import Section from '@/components/ui/Section.astro';
import SectionHeader from '@/components/common/SectionHeader.astro';
import Card from '@/components/ui/Card.astro';
import OpeningHoursSection from '@/components/sections/OpeningHoursSection.astro';
import CtaWhatsappSection from '@/components/sections/CtaWhatsappSection.astro';
import { globalConfig } from '@/config';
import { aboutContent } from '@/data';
import { getBusinessSettings } from '@/services/business.service';

const settings = await getBusinessSettings();
const { modules } = globalConfig;  // branding y módulos permanecen en globalConfig
const aboutModule = modules.pages.about;
---

<MainLayout
  title="Nuestra Historia"
  description={`Conoce la historia, misión y valores detrás de ${settings.name}, tu cafetería de confianza en ${settings.city ?? ''}.`}
>
  <!-- ── Encabezado ──────────────────────────────────────────────────────── -->
  <Section bg="secondary" size="md">
    <div class="max-w-2xl mx-auto text-center">
      <h1 class="text-4xl font-bold tracking-tight mb-3" style="color: var(--color-primary);">
        Sobre Nosotros
      </h1>
      <p class="text-lg" style="color: var(--color-text-muted);">
        Conoce la historia y los valores detrás de {settings.name}.
      </p>
    </div>
  </Section>

  <!-- ── Historia ────────────────────────────────────────────────────────── -->
  <Section bg="default" size="md">
    <div class="max-w-3xl mx-auto">
      <SectionHeader title="Nuestra historia" align="left" />
      <div class="space-y-5">
        {aboutContent.story.map((paragraph) => (
          <p class="text-lg leading-relaxed" style="color: var(--color-text);">
            {paragraph}
          </p>
        ))}
      </div>
    </div>
  </Section>

  <!-- ── Misión ──────────────────────────────────────────────────────────── -->
  {aboutContent.mission && (
    <Section bg="surface" size="md">
      <div class="max-w-3xl mx-auto text-center">
        <p
          class="text-sm font-semibold uppercase tracking-widest mb-4"
          style="color: var(--color-accent);"
        >
          Nuestra misión
        </p>
        <blockquote
          class="text-2xl font-semibold leading-snug"
          style="color: var(--color-primary);"
        >
          "{aboutContent.mission}"
        </blockquote>
      </div>
    </Section>
  )}

  <!-- ── Diferenciadores ─────────────────────────────────────────────────── -->
  {aboutContent.differentiators && aboutContent.differentiators.length > 0 && (
    <Section bg="default" size="md">
      <SectionHeader
        title="Lo que nos hace distintos"
        subtitle="Cada detalle de nuestra propuesta está pensado para ofrecerte algo genuino."
        align="center"
      />
      <ul class="grid gap-5 grid-cols-1 sm:grid-cols-2 max-w-4xl mx-auto">
        {aboutContent.differentiators.map((item) => (
          <li>
            <Card variant="flat" class="h-full">
              <div class="flex gap-4 p-6">
                {item.icon && (
                  <span class="text-3xl shrink-0 leading-none mt-0.5" aria-hidden="true">
                    {item.icon}
                  </span>
                )}
                <div>
                  <h3
                    class="font-semibold mb-1"
                    style="color: var(--color-text);"
                  >
                    {item.title}
                  </h3>
                  <p class="text-sm leading-relaxed" style="color: var(--color-text-muted);">
                    {item.description}
                  </p>
                </div>
              </div>
            </Card>
          </li>
        ))}
      </ul>
    </Section>
  )}

  <!-- ── Ubicación y contacto ────────────────────────────────────────────── -->
  <Section bg="surface" size="md">
    <div class="max-w-3xl mx-auto">
      <SectionHeader title="Dónde encontrarnos" align="left" />
      <ul class="space-y-4" style="color: var(--color-text);">

        <!-- Dirección -->
        <li class="flex items-start gap-3">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="size-5 mt-0.5 shrink-0"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            style="color: var(--color-primary);"
            aria-hidden="true"
          >
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          <span>
            {settings.address ? `${settings.address}, ` : ''}{settings.city ?? ''}{settings.country ? `, ${settings.country}` : ''}
          </span>
        </li>

        <!-- Teléfono -->
        {settings.phone && (
          <li class="flex items-center gap-3">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="size-5 shrink-0"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              style="color: var(--color-primary);"
              aria-hidden="true"
            >
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <a
              href={`tel:${settings.phone}`}
              class="hover:underline"
              style="color: var(--color-text);"
            >
              {settings.phone}
            </a>
          </li>
        )}

        <!-- Email -->
        {settings.email && (
          <li class="flex items-center gap-3">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="size-5 shrink-0"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              style="color: var(--color-primary);"
              aria-hidden="true"
            >
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <a
              href={`mailto:${settings.email}`}
              class="hover:underline"
              style="color: var(--color-text);"
            >
              {settings.email}
            </a>
          </li>
        )}

      </ul>
    </div>
  </Section>

  <!-- ── Horarios ────────────────────────────────────────────────────────── -->
  {(settings.hours ?? []).length > 0 && (
    <OpeningHoursSection
      hours={settings.hours ?? []}
      title="Horarios de atención"
      bg="default"
      size="md"
    />
  )}

  <!-- ── CTA WhatsApp ────────────────────────────────────────────────────── -->
  {settings.whatsapp && aboutModule.cta && (
    <CtaWhatsappSection
      title={aboutModule.cta.title}
      subtitle={aboutModule.cta.subtitle}
      buttonLabel={aboutModule.cta.buttonLabel}
      message={aboutModule.cta.message}
      bg="secondary"
      size="md"
    />
  )}

</MainLayout>
