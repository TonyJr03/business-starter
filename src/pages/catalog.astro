---
import MainLayout from '@/layouts/MainLayout.astro';
import Section from '@/components/ui/Section.astro';
import SectionHeader from '@/components/common/SectionHeader.astro';
import ProductCard from '@/components/catalog/ProductCard.astro';
import CategoryNav from '@/components/catalog/CategoryNav.astro';
import CtaWhatsappSection from '@/components/sections/CtaWhatsappSection.astro';
import { globalConfig } from '@/config';
import { getCategories, getProducts, getFeaturedProducts } from '@/services/catalog.service';
import { getWhatsAppUrl } from '@/lib/whatsapp';

const { identity, modules, contact, seoDefaults } = globalConfig;
const name = identity.name;

// Delegamos filtrado y ordenación al servicio de dominio.
// Las categorías y los productos por categoría vienen ya listos para renderizar.
const [categories, featuredProducts] = await Promise.all([
  getCategories(),
  getFeaturedProducts(),
]);

// Incluimos no-disponibles para que el componente muestre el badge "Agotado".
const productsByCategory = await Promise.all(
  categories.map(async (cat) => ({
    category: cat,
    products: await getProducts({ categoryId: cat.id, onlyAvailable: false }),
  }))
);

/**
 * Genera la URL de WhatsApp para un producto concreto.
 * Cuando el módulo de carrito se active, este helper dejará de usarse.
 */
function productOrderUrl(productName: string): string | undefined {
  if (!contact.whatsapp) return undefined;
  return getWhatsAppUrl(`Hola ${name}, quisiera pedir: ${productName}.`);
}
---

<MainLayout
  title="Catálogo"
  description={`Explora el catálogo completo de ${name}. ${seoDefaults.defaultDescription ?? ''}`}
>

  <!-- ── Encabezado ──────────────────────────────────────────────────────── -->
  <Section bg="secondary" size="md">
    <div class="max-w-2xl mx-auto text-center">
      <h1 class="text-4xl font-bold tracking-tight mb-3" style="color: var(--color-primary);">
        Nuestro Catálogo
      </h1>
      <p class="text-lg" style="color: var(--color-text-muted);">
        Todo lo que tenemos para ofrecerte hoy.
      </p>
    </div>
  </Section>

  {!modules.core.catalog ? (
    // Módulo desactivado
    <Section bg="default" size="lg">
      <p class="text-center" style="color: var(--color-text-subtle);">
        El catálogo no está disponible en este momento.
      </p>
    </Section>

  ) : (
    <>
      {/* Nav de categorías (sticky) */}
      <CategoryNav categories={categories} />

      {/* Destacados */}
      {featuredProducts.length > 0 && (
        <Section bg="surface" size="md">
          <SectionHeader title="Destacados" align="left" />
          <ul class="grid gap-4 grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
            {featuredProducts.map((product) => (
              <li>
                <ProductCard
                  product={product}
                  orderHref={productOrderUrl(product.name)}
                />
              </li>
            ))}
          </ul>
        </Section>
      )}

      {/* Catálogo por categorías */}
      {productsByCategory.map(({ category, products }) => (
        <Section bg="default" size="md" id={category.slug}>
          {/* Cabecera de categoría */}
          <div class="flex items-center gap-4 mb-2">
            <h2
              class="text-2xl font-bold whitespace-nowrap"
              style="color: var(--color-primary);"
            >
              {category.name}
            </h2>
            <div class="flex-1 h-px" style="background-color: var(--color-border);" />
          </div>

          {category.description && (
            <p class="text-sm mb-8" style="color: var(--color-text-muted);">
              {category.description}
            </p>
          )}

          {products.length === 0 ? (
            <p class="text-sm py-4" style="color: var(--color-text-subtle);">
              Sin productos en esta categoría por el momento.
            </p>
          ) : (
            <ul class="grid gap-4 grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 mt-6">
              {products.map((product) => (
                <li>
                  <ProductCard
                    product={product}
                    orderHref={productOrderUrl(product.name)}
                  />
                </li>
              ))}
            </ul>
          )}
        </Section>
      ))}

      {/* CTA WhatsApp */}
      {contact.whatsapp && (
        <CtaWhatsappSection
          title="¿Ves algo que te gusta?"
          subtitle="Escríbenos por WhatsApp y te atendemos de inmediato."
          buttonLabel="Hacer un pedido"
          message={`Hola ${name}, quisiera hacer un pedido.`}
          bg="secondary"
          size="md"
        />
      )}
    </>
  )}

</MainLayout>
