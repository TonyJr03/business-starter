---
/**
 * Página de login del panel admin.
 *
 * Maneja GET (mostrar formulario) y POST (procesar credenciales).
 * Si el usuario ya tiene sesión activa, redirige directamente a /admin.
 */
import { createSupabaseServerClient } from '@/lib/supabase/server';
import { getUser } from '@/lib/auth';

// SSR bajo demanda — nunca prerrenderizar esta página.
export const prerender = false;

const { cookies, request, redirect } = Astro;

// Si ya hay sesión válida, no mostrar el login.
const usuario = await getUser(cookies, request);
if (usuario) {
  return redirect('/admin');
}

// Procesar el formulario cuando el método es POST.
let errorMensaje: string | null = null;

if (request.method === 'POST') {
  const formData = await request.formData();
  const email    = (formData.get('email')    as string | null)?.trim() ?? '';
  const password = (formData.get('password') as string | null)         ?? '';

  if (!email || !password) {
    errorMensaje = 'Por favor, completa todos los campos.';
  } else {
    const supabase = createSupabaseServerClient(cookies, request);
    const { error } = await supabase.auth.signInWithPassword({ email, password });

    if (error) {
      // Mensaje genérico — no revela si el email existe o no (anti-enumeración).
      errorMensaje = 'Correo o contraseña incorrectos. Intenta de nuevo.';
    } else {
      return redirect('/admin');
    }
  }
}
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Acceso admin</title>
    <!-- Importar tokens del sistema de diseño -->
    <link rel="stylesheet" href="/src/styles/global.css" />
    <style>
      /* Reset mínimo independiente del sitio público */
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      body {
        min-height: 100vh;
        display: grid;
        place-items: center;
        background-color: #F3F4F6;
        font-family: system-ui, -apple-system, sans-serif;
        color: #1A1A1A;
        -webkit-font-smoothing: antialiased;
      }

      .card {
        width: 100%;
        max-width: 400px;
        background: #FFFFFF;
        border-radius: 12px;
        box-shadow: 0 4px 24px rgba(0,0,0,0.08);
        padding: 2.5rem 2rem;
        margin: 1.5rem;
      }

      .logo-area {
        text-align: center;
        margin-bottom: 2rem;
      }

      .logo-area h1 {
        font-size: 1.25rem;
        font-weight: 700;
        color: #111827;
        margin-bottom: 0.25rem;
      }

      .logo-area p {
        font-size: 0.875rem;
        color: #6B7280;
      }

      .form-group {
        display: flex;
        flex-direction: column;
        gap: 0.375rem;
        margin-bottom: 1rem;
      }

      label {
        font-size: 0.875rem;
        font-weight: 500;
        color: #374151;
      }

      input[type="email"],
      input[type="password"] {
        width: 100%;
        padding: 0.625rem 0.875rem;
        border: 1.5px solid #D1D5DB;
        border-radius: 8px;
        font-size: 0.9375rem;
        color: #111827;
        background: #FFFFFF;
        transition: border-color 0.15s, box-shadow 0.15s;
        outline: none;
      }

      input:focus {
        border-color: #6F4E37;
        box-shadow: 0 0 0 3px rgba(111,78,55,0.12);
      }

      input[aria-invalid="true"] {
        border-color: #DC2626;
      }

      .error-banner {
        display: flex;
        align-items: flex-start;
        gap: 0.5rem;
        background: #FEF2F2;
        border: 1px solid #FECACA;
        border-radius: 8px;
        padding: 0.75rem 1rem;
        margin-bottom: 1.25rem;
        font-size: 0.875rem;
        color: #991B1B;
      }

      .error-icon {
        flex-shrink: 0;
        width: 16px;
        height: 16px;
        margin-top: 1px;
      }

      .btn-submit {
        width: 100%;
        margin-top: 0.5rem;
        padding: 0.75rem 1rem;
        background: #6F4E37;
        color: #FFFFFF;
        font-size: 0.9375rem;
        font-weight: 600;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        transition: background 0.15s, opacity 0.15s;
      }

      .btn-submit:hover  { background: #5D3E2C; }
      .btn-submit:active { opacity: 0.85; }

      .btn-submit:disabled {
        opacity: 0.6;
        cursor: not-allowed;
      }

      .btn-submit.loading {
        position: relative;
        color: transparent;
        pointer-events: none;
      }

      .btn-submit.loading::after {
        content: '';
        position: absolute;
        inset: 0;
        display: grid;
        place-items: center;
        width: 18px;
        height: 18px;
        margin: auto;
        border: 2px solid rgba(255,255,255,0.4);
        border-top-color: #FFFFFF;
        border-radius: 50%;
        animation: spin 0.6s linear infinite;
      }

      @keyframes spin { to { transform: rotate(360deg); } }

      .back-link {
        display: block;
        text-align: center;
        margin-top: 1.5rem;
        font-size: 0.8125rem;
        color: #6B7280;
        text-decoration: none;
        transition: color 0.15s;
      }

      .back-link:hover { color: #374151; }
    </style>
  </head>

  <body>
    <div class="card">
      <div class="logo-area">
        <h1>Panel de administración</h1>
        <p>Ingresa tus credenciales para continuar</p>
      </div>

      {errorMensaje && (
        <div class="error-banner" role="alert">
          <svg class="error-icon" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
          </svg>
          <span>{errorMensaje}</span>
        </div>
      )}

      <form
        method="POST"
        id="login-form"
        novalidate
      >
        <div class="form-group">
          <label for="email">Correo electrónico</label>
          <input
            id="email"
            name="email"
            type="email"
            autocomplete="email"
            placeholder="admin@negocio.com"
            required
            aria-invalid={errorMensaje ? 'true' : undefined}
          />
        </div>

        <div class="form-group">
          <label for="password">Contraseña</label>
          <input
            id="password"
            name="password"
            type="password"
            autocomplete="current-password"
            placeholder="••••••••"
            required
            aria-invalid={errorMensaje ? 'true' : undefined}
          />
        </div>

        <button
          type="submit"
          class="btn-submit"
          id="submit-btn"
        >
          Iniciar sesión
        </button>
      </form>

      <a href="/" class="back-link">← Volver al sitio</a>
    </div>

    <script>
      // Validación mínima en cliente antes de enviar el formulario.
      const form      = document.getElementById('login-form') as HTMLFormElement;
      const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

      form.addEventListener('submit', (e) => {
        const email    = (form.elements.namedItem('email')    as HTMLInputElement).value.trim();
        const password = (form.elements.namedItem('password') as HTMLInputElement).value;

        if (!email || !password) {
          e.preventDefault();

          const emailInput    = form.elements.namedItem('email')    as HTMLInputElement;
          const passwordInput = form.elements.namedItem('password') as HTMLInputElement;

          if (!email)    emailInput.reportValidity();
          if (!password) passwordInput.reportValidity();
          return;
        }

        // Estado loading mientras el servidor procesa el POST.
        submitBtn.disabled = true;
        submitBtn.classList.add('loading');
        submitBtn.textContent = 'Entrando…';
      });
    </script>
  </body>
</html>
