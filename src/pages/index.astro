---
import MainLayout from '@/layouts/MainLayout.astro';
import HomeSectionRenderer from '@/components/sections/HomeSectionRenderer.astro';
import { businessConfig, homeSections } from '@/config';

const { name, tagline, description } = businessConfig;

const activeSections = homeSections
  .filter(s => s.enabled)
  .sort((a, b) => a.order - b.order);
---

<MainLayout
  title={`${name} · ${tagline}`}
  standaloneTitle
  description={description}
>
  {activeSections.map(section => (
    <HomeSectionRenderer section={section} />
  ))}
</MainLayout>
