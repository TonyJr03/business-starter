---
import MainLayout from '@/layouts/MainLayout.astro';
import HomeSectionRenderer from '@/components/sections/HomeSectionRenderer.astro';
import { globalConfig } from '@/config';

const { identity, seoDefaults, modules } = globalConfig;

const activeSections = modules.sections
  .filter(s => s.enabled)
  .sort((a, b) => a.order - b.order);
---

<MainLayout
  title={`${identity.name} · ${identity.tagline}`}
  standaloneTitle
  description={seoDefaults.defaultDescription}
>
  {activeSections.map(section => (
    <HomeSectionRenderer section={section} />
  ))}
</MainLayout>
