---
import MainLayout from '@/layouts/MainLayout.astro';
import HeroSection from '@/components/sections/HeroSection.astro';
import FeatureSection from '@/components/sections/FeatureSection.astro';
import CtaWhatsappSection from '@/components/sections/CtaWhatsappSection.astro';
import Section from '@/components/ui/Section.astro';
import { businessConfig } from '@/config';
import type { FeatureItem } from '@/components/sections/FeatureSection.astro';

// ── Datos de la sección de características ─────────────────────────────────
// Personaliza estos ítems para cada negocio.
const features: FeatureItem[] = [
  {
    icon: '✨',
    title: 'Calidad artesanal',
    description: 'Cada producto elaborado con los mejores ingredientes locales y con el cuidado de siempre.',
  },
  {
    icon: '📍',
    title: businessConfig.address.city,
    description: `Encuéntranos en ${businessConfig.address.street}, ${businessConfig.address.municipality}.`,
  },
  {
    icon: '🕐',
    title: 'Abierto toda la semana',
    description: 'Horario extendido para que disfrutes cuando lo necesites.',
  },
];
---

<MainLayout
  title="Inicio"
  description={businessConfig.shortDescription}
>

  <!-- ── Hero ────────────────────────────────────────────────────────────── -->
  <HeroSection
    tagline={businessConfig.tagline}
    title={businessConfig.name}
    subtitle={businessConfig.shortDescription}
    primaryCta={{ label: 'Ver Menú', href: '/menu' }}
    secondaryCta={{ label: 'Contáctanos', href: '/contacto' }}
    bg="secondary"
    size="lg"
  />

  <!-- ── Características ─────────────────────────────────────────────────── -->
  <FeatureSection
    title="¿Por qué elegirnos?"
    subtitle={businessConfig.description}
    items={features}
    columns={3}
    bg="surface"
    size="md"
  />

  <!-- ── Horarios ────────────────────────────────────────────────────────── -->
  {businessConfig.openingHours.length > 0 && (
    <Section bg="default" size="md">
      <div class="max-w-lg mx-auto">
        <h2 class="text-3xl font-bold mb-8 text-center" style="color: var(--color-primary);">
          Horarios
        </h2>
        <ul
          class="rounded-xl overflow-hidden shadow-(--shadow-card) border border-(--color-border)"
          style="background-color: var(--color-bg);"
        >
          {businessConfig.openingHours.map((entry) => (
            <li
              class="flex justify-between items-center px-6 py-3"
              style="border-bottom: 1px solid var(--color-border-subtle);"
            >
              <span class="text-sm font-medium" style="color: var(--color-text);">
                {entry.day}
              </span>
              {entry.isClosed
                ? <span class="text-xs font-semibold" style="color: var(--color-error);">Cerrado</span>
                : <span class="text-sm" style="color: var(--color-text-muted);">{entry.open} – {entry.close}</span>
              }
            </li>
          ))}
        </ul>
      </div>
    </Section>
  )}

  <!-- ── CTA WhatsApp — visible solo si hay número configurado ───────────── -->
  {businessConfig.contact.whatsappNumber && (
    <CtaWhatsappSection
      title="¿Listo para pedir?"
      subtitle="Escríbenos directamente por WhatsApp y te atendemos al momento."
      buttonLabel="Escribir ahora"
      message={`Hola ${businessConfig.name}, me gustaría hacer una consulta.`}
      bg="secondary"
      size="md"
    />
  )}

</MainLayout>
