---
import MainLayout from '@/layouts/MainLayout.astro';
import HeroSection from '@/components/sections/HeroSection.astro';
import FeatureSection from '@/components/sections/FeatureSection.astro';
import OpeningHoursSection from '@/components/sections/OpeningHoursSection.astro';
import CtaWhatsappSection from '@/components/sections/CtaWhatsappSection.astro';
import { businessConfig } from '@/config';
import { homeFeatures } from '@/data';

const { name, tagline, shortDescription, description, contact, openingHours } = businessConfig;
const ctaMessage = `Hola ${name}, me gustaría hacer una consulta.`;
---

<MainLayout
  title={`${name} · ${tagline}`}
  standaloneTitle
  description={description}
>

  <!-- ── Hero ────────────────────────────────────────────────────────────── -->
  <HeroSection
    tagline={tagline}
    title={name}
    subtitle={shortDescription}
    primaryCta={{ label: 'Ver Menú', href: '/menu' }}
    secondaryCta={{ label: 'Contáctanos', href: '/contact' }}
    bg="secondary"
    size="lg"
  />

  <!-- ── Por qué elegirnos ───────────────────────────────────────────────── -->
  <FeatureSection
    title="¿Por qué elegirnos?"
    subtitle={description}
    items={homeFeatures}
    columns={3}
    bg="surface"
    size="md"
  />

  <!-- ── Horarios (si hay horarios definidos) ────────────────────────────── -->
  {openingHours.length > 0 && (
    <OpeningHoursSection
      hours={openingHours}
      bg="default"
      size="md"
    />
  )}

  <!-- ── CTA WhatsApp (si hay número configurado) ────────────────────────── -->
  {contact.whatsappNumber && (
    <CtaWhatsappSection
      title="¿Listo para ordenar?"
      subtitle="Escríbenos directamente por WhatsApp y te atendemos al momento."
      buttonLabel="Escribir ahora"
      message={ctaMessage}
      bg="secondary"
      size="md"
    />
  )}

</MainLayout>
