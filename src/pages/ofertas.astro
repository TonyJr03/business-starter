---
import MainLayout from '@/layouts/MainLayout.astro';
---

<MainLayout title="Ofertas">
  <section class="py-24 px-4 text-center">
    <div class="max-w-2xl mx-auto">
      <h1 class="text-4xl font-bold mb-4" style="color: var(--color-primary);">Ofertas y Promociones</h1>
      <p class="text-gray-600 text-lg mb-3">Próximamente nuestras promociones especiales.</p>
      <p class="text-sm text-gray-400 inline-flex items-center gap-2 bg-gray-100 px-4 py-2 rounded-full">
        <svg xmlns="http://www.w3.org/2000/svg" class="size-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M12 2a10 10 0 110 20A10 10 0 0112 2z" />
        </svg>
        Las promociones se implementarán en el Sprint 4.
      </p>
    </div>
  </section>
</MainLayout>