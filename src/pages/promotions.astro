---
import MainLayout from '@/layouts/MainLayout.astro';
import Section from '@/components/ui/Section.astro';
import PromotionCard from '@/components/catalog/PromotionCard.astro';
import type { PromoStatus } from '@/components/catalog/PromotionCard.astro';
import CtaWhatsappSection from '@/components/sections/CtaWhatsappSection.astro';
import { globalConfig } from '@/config';
import { getPromotions, getPromotionStatus } from '@/services/promotions.service';
import { getWhatsAppUrl } from '@/lib/whatsapp';

const { identity, modules, contact, pages } = globalConfig;
const name = identity.name;
const promoModule = modules.pages.promotions;
const promoCopy = pages.promotions;

// Traemos todas —activas e inactivas— para mostrar estado visual completo.
const allPromos = await getPromotions();

// ── Derivar estado (build-time) ─────────────────────────────────────────────
// getPromotionStatus devuelve los 4 estados del dominio; PromotionCard los
// representa todos (active / upcoming / paused / expired).
const today = new Date();

function getStatus(promo: typeof allPromos[number]): PromoStatus {
  return getPromotionStatus(promo, today);
}

// ── Formatear rango de fechas legible ───────────────────────────────────────
const dateFormatter = new Intl.DateTimeFormat('es-CU', {
  day:   'numeric',
  month: 'long',
  year:  'numeric',
  timeZone: 'America/Havana',
});

function formatDateRange(startsAt?: string, endsAt?: string): string | undefined {
  if (!startsAt && !endsAt) return undefined;
  const parts: string[] = [];
  if (startsAt) parts.push(`Desde el ${dateFormatter.format(new Date(startsAt + 'T00:00:00'))}`);
  if (endsAt)   parts.push(`hasta el ${dateFormatter.format(new Date(endsAt   + 'T00:00:00'))}`);
  return parts.join(' ');
}

// ── Enriquecer promos con estado y url ──────────────────────────────────────
const enriched = allPromos.map((promo) => {
  const status   = getStatus(promo);
  const dateRange = formatDateRange(promo.startsAt, promo.endsAt);
  const orderHref = contact.whatsapp
    ? getWhatsAppUrl(`Hola ${name}, quisiera aprovechar la oferta: ${promo.title}.`)
    : undefined;
  return { promo, status, dateRange, orderHref };
});

const activeCount = enriched.filter((e) => e.status === 'active').length;
---

<MainLayout
  title="Promociones"
  description={`Descubre las promociones y ofertas especiales de ${name}. ${activeCount > 0 ? `${activeCount} ${activeCount === 1 ? 'oferta activa' : 'ofertas activas'} ahora mismo.` : ''}`}
>

  <!-- ── Encabezado ──────────────────────────────────────────────────────── -->
  <Section bg="secondary" size="md">
    <div class="max-w-2xl mx-auto text-center">
      <h1 class="text-4xl font-bold tracking-tight mb-3" style="color: var(--color-primary);">
        {promoCopy.heading}
      </h1>
      <p class="text-lg" style="color: var(--color-text-muted);">
        {activeCount > 0
          ? `${activeCount} promoción${activeCount > 1 ? 'es' : ''} activa${activeCount > 1 ? 's' : ''} ahora mismo.`
          : promoCopy.emptyMessage}
      </p>
    </div>
  </Section>

  {!promoModule.enabled ? (
    // Módulo desactivado
    <Section bg="default" size="lg">
      <p class="text-center" style="color: var(--color-text-subtle);">
        Las promociones no están disponibles en este momento.
      </p>
    </Section>

  ) : enriched.length === 0 ? (
    // Sin datos
    <Section bg="default" size="lg">
      <p class="text-center" style="color: var(--color-text-subtle);">
        No hay promociones registradas en este momento.
      </p>
    </Section>

  ) : (
    // Lista de promociones
    <Section bg="default" size="md">
      <ul class="grid gap-6 grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 max-w-5xl mx-auto">
        {enriched.map(({ promo, status, dateRange, orderHref }) => (
          <li>
            <PromotionCard
              promotion={promo}
              status={status}
              dateRange={dateRange}
              orderHref={orderHref}
            />
          </li>
        ))}
      </ul>
    </Section>
  )}

  <!-- ── CTA WhatsApp ────────────────────────────────────────────────────── -->
  {contact.whatsapp && promoModule.cta && (
    <CtaWhatsappSection
      title={promoModule.cta.title}
      subtitle={promoModule.cta.subtitle}
      buttonLabel={promoModule.cta.buttonLabel}
      message={promoModule.cta.message}
      bg="secondary"
      size="md"
    />
  )}

</MainLayout>
