---
import MainLayout from '@/layouts/MainLayout.astro';
import { siteConfig } from '@/config';
---

<MainLayout title="Nosotros">
  <!-- Encabezado -->
  <section class="py-20 px-4 text-center" style="background-color: var(--color-secondary);">
    <div class="max-w-3xl mx-auto">
      <h1 class="text-4xl font-bold mb-4" style="color: var(--color-primary);">Sobre Nosotros</h1>
      <p class="text-gray-600 text-lg">Conoce la historia detrás de {siteConfig.name}.</p>
    </div>
  </section>

  <!-- Historia -->
  <section class="py-20 px-4">
    <div class="max-w-3xl mx-auto space-y-6">
      <p class="text-gray-700 leading-relaxed text-lg">
        Café La Esquina nació en 2018 de la mano de dos amigos habaneros con un sueño sencillo: crear un espacio donde el café de verdad tuviera el protagonismo que merece. Lo que empezó como un pequeño local en el Vedado se convirtió rápidamente en el punto de encuentro favorito del barrio.
      </p>
      <p class="text-gray-700 leading-relaxed text-lg">
        Trabajamos con granos de café cubano de primera calidad, tostados de forma artesanal para preservar cada matiz de sabor. Nuestro equipo está formado por personas apasionadas por la buena atención y el ambiente tranquilo, donde cada visita se siente como en casa.
      </p>
      <p class="text-gray-700 leading-relaxed text-lg">
        Hoy seguimos fieles a esa misma filosofía: café de calidad, trato cercano y un rincón acogedor en el corazón de La Habana.
      </p>
    </div>
  </section>

  <!-- Ubicación -->
  <section class="py-20 px-4" style="background-color: var(--color-surface);">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-2xl font-bold mb-6" style="color: var(--color-primary);">Dónde encontrarnos</h2>
      <ul class="space-y-3 text-gray-700">
        <li class="flex items-start gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" class="size-5 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color: var(--color-primary);">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          <span>{siteConfig.address}, {siteConfig.municipality}, {siteConfig.city}</span>
        </li>
        {siteConfig.phone && (
          <li class="flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="size-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color: var(--color-primary);">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <span>{siteConfig.phone}</span>
          </li>
        )}
      </ul>
    </div>
  </section>

  <!-- Horarios -->
  <section class="py-20 px-4">
    <div class="max-w-lg mx-auto">
      <h2 class="text-2xl font-bold mb-8" style="color: var(--color-primary);">Horarios de atención</h2>
      <ul class="divide-y divide-gray-200 rounded-xl overflow-hidden shadow-sm bg-white border border-gray-100">
        {siteConfig.openingHours.map((entry) => (
          <li class="flex justify-between items-center px-6 py-3">
            <span class="font-medium text-gray-800">{entry.day}</span>
            {entry.isClosed
              ? <span class="text-red-500 text-sm font-semibold">Cerrado</span>
              : <span class="text-gray-600 text-sm">{entry.open} – {entry.close}</span>
            }
          </li>
        ))}
      </ul>
    </div>
  </section>
</MainLayout>