---
/**
 * AdminLayout — Layout base del panel administrativo.
 *
 * Completamente separado de MainLayout y del sitio público.
 * Estructura: sidebar fijo a la izquierda + área de contenido principal.
 *
 * @prop titulo - Título de la sección actual (aparece en el header interno)
 * @prop usuario - Email o nombre del usuario autenticado (opcional, para mostrar en header)
 */
import AdminSidebar from '@/components/admin/AdminSidebar.astro';
import '@/styles/global.css';

interface Props {
  titulo: string;
  usuario?: string;
}

const { titulo, usuario } = Astro.props;
const rutaActual = Astro.url.pathname.replace(/\/$/, '') || '/admin';
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{titulo} — Admin</title>
    <!-- No indexar el panel de administración -->
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>

  <body>
    <div class="admin-shell">
      <!-- Sidebar de navegación -->
      <AdminSidebar rutaActual={rutaActual} />

      <!-- Área de contenido -->
      <div class="admin-content">
        <!-- Header interno del panel -->
        <header class="admin-header">
          <h1 class="admin-header__title">{titulo}</h1>

          <div class="admin-header__actions">
            {usuario && (
              <span class="admin-header__user" title={usuario}>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/>
                  <circle cx="12" cy="7" r="4"/>
                </svg>
                {usuario}
              </span>
            )}

            <!-- Logout via formulario POST — sin JS requerido -->
            <form method="POST" action="/admin/logout" class="logout-form">
              <button type="submit" class="btn-logout">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/>
                  <polyline points="16 17 21 12 16 7"/>
                  <line x1="21" y1="12" x2="9" y2="12"/>
                </svg>
                Cerrar sesión
              </button>
            </form>
          </div>
        </header>

        <!-- Contenido de la página -->
        <main class="admin-main">
          <slot />
        </main>
      </div>
    </div>

    <style>
      /* ── Reset y base ───────────────────────────────────────────────── */
      *, *::before, *::after { box-sizing: border-box; }

      body {
        margin: 0;
        font-family: system-ui, -apple-system, sans-serif;
        background: #F3F4F6;
        color: #111827;
        -webkit-font-smoothing: antialiased;
      }

      /* ── Shell: sidebar + contenido en fila ─────────────────────────── */
      .admin-shell {
        display: flex;
        min-height: 100vh;
      }

      .admin-content {
        flex: 1;
        display: flex;
        flex-direction: column;
        min-width: 0; /* evita overflow con contenidos anchos */
      }

      /* ── Header interno ─────────────────────────────────────────────── */
      .admin-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        padding: 0 1.5rem;
        height: 56px;
        background: #FFFFFF;
        border-bottom: 1px solid #E5E7EB;
        flex-shrink: 0;
      }

      .admin-header__title {
        font-size: 1rem;
        font-weight: 600;
        color: #111827;
        margin: 0;
      }

      .admin-header__actions {
        display: flex;
        align-items: center;
        gap: 1rem;
      }

      .admin-header__user {
        display: flex;
        align-items: center;
        gap: 0.375rem;
        font-size: 0.8125rem;
        color: #6B7280;
        max-width: 200px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }

      /* ── Botón logout ───────────────────────────────────────────────── */
      .logout-form { margin: 0; }

      .btn-logout {
        display: flex;
        align-items: center;
        gap: 0.375rem;
        padding: 0.375rem 0.75rem;
        font-size: 0.8125rem;
        font-weight: 500;
        color: #374151;
        background: transparent;
        border: 1px solid #D1D5DB;
        border-radius: 6px;
        cursor: pointer;
        transition: background 0.15s, color 0.15s, border-color 0.15s;
      }

      .btn-logout:hover {
        background: #FEF2F2;
        color: #991B1B;
        border-color: #FECACA;
      }

      /* ── Área de contenido principal ────────────────────────────────── */
      .admin-main {
        flex: 1;
        padding: 1.75rem 1.5rem;
        overflow-y: auto;
      }

      /* ── Responsive: sidebar colapsado en mobile ─────────────────────
         (Expansión completa queda para Sprint 13+)                    */
      @media (max-width: 768px) {
        .admin-shell {
          flex-direction: column;
        }
      }

      /* ════════════════════════════════════════════════════════════════
         Utilidades compartidas del panel admin
         Heredadas por todas las páginas /admin/*
         ════════════════════════════════════════════════════════════════ */

      /* ── Cabecera de página ─────────────────────────────────────── */
      .page-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 1.5rem;
      }
      .page-title    { font-size: 1.125rem; font-weight: 600; color: #111827; margin: 0; }
      .page-subtitle { font-size: 0.875rem; color: #6B7280; margin: 0.25rem 0 0; }

      /* ── Enlace volver ──────────────────────────────────────────── */
      .back-link {
        display: inline-flex;
        align-items: center;
        gap: 0.375rem;
        font-size: 0.8125rem;
        color: #6B7280;
        text-decoration: none;
        margin-bottom: 1.25rem;
      }
      .back-link:hover { color: #111827; }

      /* ── Botones ────────────────────────────────────────────────── */
      .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.375rem;
        padding: 0.5rem 1rem;
        font-size: 0.875rem;
        font-weight: 500;
        border-radius: 6px;
        cursor: pointer;
        text-decoration: none;
        border: 1px solid transparent;
        white-space: nowrap;
        transition: background 0.15s, border-color 0.15s, color 0.15s;
      }
      .btn--primary   { background: #111827; color: #FFFFFF; border-color: #111827; }
      .btn--primary:hover   { background: #1F2937; border-color: #1F2937; }
      .btn--secondary { background: #FFFFFF; color: #374151; border-color: #D1D5DB; }
      .btn--secondary:hover { background: #F9FAFB; }
      .btn--danger    { background: #FEF2F2; color: #991B1B; border-color: #FECACA; }
      .btn--danger:hover    { background: #FEE2E2; border-color: #FCA5A5; }
      .btn--ghost     { background: transparent; color: #6B7280; border-color: transparent; }
      .btn--ghost:hover     { background: #F3F4F6; color: #374151; }
      .btn--sm { padding: 0.25rem 0.625rem; font-size: 0.8125rem; }

      /* ── Tarjeta ────────────────────────────────────────────────── */
      .card         { background: #FFFFFF; border: 1px solid #E5E7EB; border-radius: 8px; }
      .card--padded { padding: 1.5rem; }

      /* ── Alertas ────────────────────────────────────────────────── */
      .alert {
        padding: 0.75rem 1rem;
        border-radius: 6px;
        font-size: 0.875rem;
        margin-bottom: 1.25rem;
      }
      .alert--error   { background: #FEF2F2; color: #991B1B; border: 1px solid #FECACA; }
      .alert--success { background: #F0FDF4; color: #166534; border: 1px solid #BBF7D0; }

      /* ── Badges de estado ───────────────────────────────────────── */
      .badge {
        display: inline-flex;
        align-items: center;
        padding: 0.125rem 0.5rem;
        border-radius: 9999px;
        font-size: 0.75rem;
        font-weight: 500;
      }
      .badge--active   { background: #DCFCE7; color: #166534; }
      .badge--inactive { background: #F3F4F6; color: #6B7280; }

      /* ── Tabla de datos ─────────────────────────────────────────── */
      .data-table { width: 100%; border-collapse: collapse; font-size: 0.875rem; }
      .data-table th {
        padding: 0.625rem 1rem;
        text-align: left;
        font-size: 0.75rem;
        font-weight: 600;
        color: #6B7280;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        background: #F9FAFB;
        border-bottom: 1px solid #E5E7EB;
      }
      .data-table td {
        padding: 0.75rem 1rem;
        color: #374151;
        border-bottom: 1px solid #F3F4F6;
        vertical-align: middle;
      }
      .data-table tr:last-child td    { border-bottom: none; }
      .data-table tr:hover td         { background: #FAFAFA; }
      .data-table .col-actions        { text-align: right; width: 80px; }

      /* ── Estado vacío ───────────────────────────────────────────── */
      .empty-state {
        text-align: center;
        padding: 3rem 1rem;
        color: #9CA3AF;
        font-size: 0.875rem;
      }
      .empty-state a           { color: #6B7280; text-decoration: underline; }
      .empty-state a:hover     { color: #111827; }

      /* ── Formularios ────────────────────────────────────────────── */
      .form-grid  { display: grid; gap: 1.25rem; }
      .form-group { display: flex; flex-direction: column; gap: 0.375rem; }
      .form-label { font-size: 0.875rem; font-weight: 500; color: #374151; }
      .form-label--required::after { content: ' *'; color: #EF4444; font-weight: 400; }

      .form-input,
      .form-textarea,
      .form-select {
        border: 1px solid #D1D5DB;
        border-radius: 6px;
        padding: 0.5rem 0.75rem;
        font-size: 0.875rem;
        color: #111827;
        background: #FFFFFF;
        width: 100%;
        outline: none;
        font-family: inherit;
        transition: border-color 0.15s, box-shadow 0.15s;
      }
      .form-input:focus,
      .form-textarea:focus,
      .form-select:focus {
        border-color: #6B7280;
        box-shadow: 0 0 0 3px rgba(107, 114, 128, 0.12);
      }
      .form-input--readonly { background: #F9FAFB; color: #6B7280; cursor: default; }
      .form-input--error,
      .form-textarea--error { border-color: #EF4444; }
      .form-textarea { resize: vertical; min-height: 80px; }

      .form-hint        { font-size: 0.8125rem; color: #9CA3AF; }
      .form-field-error { font-size: 0.8125rem; color: #EF4444; }

      .form-checkbox-row {
        display: flex;
        align-items: center;
        gap: 0.5rem;
      }
      .form-checkbox {
        width: 16px;
        height: 16px;
        cursor: pointer;
        accent-color: #111827;
        flex-shrink: 0;
      }

      /* ── Acciones del formulario ────────────────────────────────── */
      .form-actions {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding-top: 1.5rem;
        border-top: 1px solid #E5E7EB;
        margin-top: 0.5rem;
      }

      /* ── Zona de peligro ────────────────────────────────────────── */
      .danger-zone {
        margin-top: 2rem;
        padding: 1.25rem 1.5rem;
        border: 1px solid #FECACA;
        border-radius: 8px;
        background: #FFFAFA;
      }
      .danger-zone__title { font-size: 0.875rem; font-weight: 600; color: #991B1B; margin: 0 0 0.375rem; }
      .danger-zone__desc  { font-size: 0.8125rem; color: #B91C1C; margin: 0 0 1rem; }

      /* ── Hub de secciones (ej. /admin/catalog) ──────────────────── */
      .hub-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
        gap: 1rem;
      }
      .hub-card {
        display: flex;
        flex-direction: column;
        gap: 0.375rem;
        padding: 1.25rem;
        background: #FFFFFF;
        border: 1px solid #E5E7EB;
        border-radius: 8px;
        text-decoration: none;
        color: #111827;
        transition: border-color 0.15s, box-shadow 0.15s;
      }
      .hub-card:hover         { border-color: #9CA3AF; box-shadow: 0 1px 4px rgba(0,0,0,0.07); }
      .hub-card__title        { font-size: 0.9375rem; font-weight: 600; }
      .hub-card__desc         { font-size: 0.8125rem; color: #6B7280; }
      .hub-card--disabled     { opacity: 0.5; pointer-events: none; cursor: default; }

      /* ── Slug en tabla ──────────────────────────────────────────── */
      .row-slug {
        font-family: ui-monospace, 'Cascadia Code', monospace;
        font-size: 0.8125rem;
        color: #6B7280;
        background: #F3F4F6;
        padding: 0.125rem 0.375rem;
        border-radius: 4px;
      }
    </style>
  </body>
</html>
