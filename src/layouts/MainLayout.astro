---
import { globalConfig, themeConfig } from '@/config';
import Header from '@/components/common/Header.astro';
import Footer from '@/components/common/Footer.astro';
import '@/styles/global.css';

interface Props {
  title: string;
  description?: string;
  /** Imagen para og:image (ruta absoluta o URL). */
  ogImage?: string;
  /**
   * Cuando true, el <title> se usa tal cual (sin el sufijo del negocio).
   * Útil para la home, donde el título ya incluye el nombre del negocio.
   */
  standaloneTitle?: boolean;
}

const { title, description, ogImage, standaloneTitle = false } = Astro.props;

const { seoDefaults, identity } = globalConfig;

// Aplica la plantilla de título configurable ("%s | Nombre del negocio").
const pageTitle = standaloneTitle
  ? title
  : seoDefaults.titleTemplate.replace('%s', title);

// Usa la descripción de la página si existe; si no, la descripción por defecto del negocio.
const pageDescription = description ?? seoDefaults.defaultDescription;

// Imagen OG: prioridad → prop de página → og:image por defecto del negocio.
const resolvedOgImage = ogImage ?? seoDefaults.ogImage;

const canonicalUrl = Astro.url.href;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={identity.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonicalUrl} />
    {resolvedOgImage && <meta property="og:image" content={resolvedOgImage} />}
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    {resolvedOgImage && <meta name="twitter:image" content={resolvedOgImage} />}
    <!-- Tokens de marca: sobreescriben los defaults de tokens.css por negocio -->
    <style define:vars={{
      colorPrimary:        themeConfig.colors.primary,
      colorSecondary:      themeConfig.colors.secondary,
      colorAccent:         themeConfig.colors.accent,
      colorFooterBg:       themeConfig.colors.footerBg,
      colorFooterText:     themeConfig.colors.footerText,
      colorFooterMuted:    themeConfig.colors.footerTextMuted,
      colorFooterBorder:   themeConfig.colors.footerBorder,
      fontHeading:         themeConfig.fonts.heading,
      fontBody:            themeConfig.fonts.body,
    }}>
      :root {
        --color-primary:            var(--colorPrimary);
        --color-secondary:          var(--colorSecondary);
        --color-accent:             var(--colorAccent);
        --color-footer-bg:          var(--colorFooterBg);
        --color-footer-text:        var(--colorFooterText);
        --color-footer-text-muted:  var(--colorFooterMuted);
        --color-footer-border:      var(--colorFooterBorder);
        --font-heading:             var(--fontHeading);
        --font-body:                var(--fontBody);
      }
    </style>
  </head>
  <body class="min-h-screen flex flex-col">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
