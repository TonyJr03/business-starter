---
import { globalConfig } from '@/config';
import Header from '@/components/common/Header.astro';
import Footer from '@/components/common/Footer.astro';
import '@/styles/global.css';

interface Props {
  title: string;
  description?: string;
  /** Imagen para og:image (ruta absoluta o URL). */
  ogImage?: string;
  /**
   * Cuando true, el <title> se usa tal cual (sin el sufijo del negocio).
   * Útil para la home, donde el título ya incluye el nombre del negocio.
   */
  standaloneTitle?: boolean;
}

const { title, description, ogImage, standaloneTitle = false } = Astro.props;

const { seoDefaults, identity, branding } = globalConfig;

// ── SEO ───────────────────────────────────────────────────────────────────────
// Aplica la plantilla de título configurable ("%s | Nombre del negocio").
const pageTitle = standaloneTitle
  ? title
  : seoDefaults.titleTemplate.replace('%s', title);

// Usa la descripción de la página si existe; si no, la descripción por defecto del negocio.
const pageDescription = description ?? seoDefaults.defaultDescription;

// Imagen OG: prioridad → prop de página → og:image por defecto del negocio.
const resolvedOgImage = ogImage ?? seoDefaults.ogImage;

const canonicalUrl = Astro.url.href;

// ── Branding / CSS vars ───────────────────────────────────────────────────────
// Los fallbacks coinciden con los defaults de tokens.css para que cualquier
// campo no definido en `branding` simplemente aplique el token base.
// `themeKey` se expone como atributo data-theme en <html> para que futuras
// skins puedan sobrescribir tokens mediante selectores [data-theme="xxx"].
const { colors = {}, typography = {} } = branding;

const brandVars = {
  colorPrimary:     colors.primary         ?? '#6F4E37',
  colorSecondary:   colors.secondary       ?? '#F5E6D3',
  colorAccent:      colors.accent          ?? '#D4A574',
  colorFooterBg:    colors.footerBg        ?? '#111827',
  colorFooterText:  colors.footerText      ?? '#FFFFFF',
  colorFooterMuted: colors.footerTextMuted ?? '#9CA3AF',
  colorFooterBorder:colors.footerBorder    ?? '#1F2937',
  fontHeading:      typography.heading     ?? "'Inter', system-ui, sans-serif",
  fontBody:         typography.body        ?? "'Inter', system-ui, sans-serif",
};
---

<!doctype html>
<html lang="es" data-theme={branding.themeKey ?? 'default'}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={identity.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonicalUrl} />
    {resolvedOgImage && <meta property="og:image" content={resolvedOgImage} />}
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    {resolvedOgImage && <meta name="twitter:image" content={resolvedOgImage} />}
    <!-- Tokens de marca: inyectados desde globalConfig.branding, sobreescriben los defaults de tokens.css -->
    <style define:vars={brandVars}>
      :root {
        --color-primary:            var(--colorPrimary);
        --color-secondary:          var(--colorSecondary);
        --color-accent:             var(--colorAccent);
        --color-footer-bg:          var(--colorFooterBg);
        --color-footer-text:        var(--colorFooterText);
        --color-footer-text-muted:  var(--colorFooterMuted);
        --color-footer-border:      var(--colorFooterBorder);
        --font-heading:             var(--fontHeading);
        --font-body:                var(--fontBody);
      }
    </style>
  </head>
  <body class="min-h-screen flex flex-col">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
