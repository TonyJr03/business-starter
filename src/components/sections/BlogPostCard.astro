---
/**
 * BlogPostCard — card de vista previa de artículo para el listado del blog.
 *
 * @prop post - BlogPost tipado
 */
import Card from '@/components/ui/Card.astro';
import type { BlogPost } from '@/types';

interface Props {
  post: BlogPost;
}

const { post } = Astro.props;

const dateFormatter = new Intl.DateTimeFormat('es-CU', {
  day:      'numeric',
  month:    'long',
  year:     'numeric',
  timeZone: 'America/Havana',
});

const formattedDate = dateFormatter.format(new Date(post.publishedAt + 'T00:00:00'));
---

<Card href={`/blog/${post.slug}`} variant="elevated" class="flex flex-col h-full group">
  <div class="flex flex-col gap-3 p-6 h-full">

    <!-- Fecha ──────────────────────────────────────────────────────────── -->
    <time
      datetime={post.publishedAt}
      class="text-xs font-semibold uppercase tracking-widest"
      style="color: var(--color-accent);"
    >
      {formattedDate}
    </time>

    <!-- Título ─────────────────────────────────────────────────────────── -->
    <h2
      class="text-lg font-bold leading-snug group-hover:underline underline-offset-2"
      style="color: var(--color-text);"
    >
      {post.title}
    </h2>

    <!-- Resumen ────────────────────────────────────────────────────────── -->
    <p class="text-sm leading-relaxed flex-1" style="color: var(--color-text-muted);">
      {post.summary}
    </p>

    <!-- Tags ───────────────────────────────────────────────────────────── -->
    {post.tags && post.tags.length > 0 && (
      <ul class="flex flex-wrap gap-1.5 mt-1" aria-label="Etiquetas">
        {post.tags.map((tag) => (
          <li
            class="text-xs px-2 py-0.5 rounded-full"
            style="background-color: var(--color-surface); color: var(--color-text-muted);"
          >
            #{tag}
          </li>
        ))}
      </ul>
    )}

    <!-- Leer más ───────────────────────────────────────────────────────── -->
    <span
      class="mt-2 text-sm font-semibold"
      style="color: var(--color-primary);"
      aria-hidden="true"
    >
      Leer artículo →
    </span>

  </div>
</Card>
