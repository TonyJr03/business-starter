---
import Button from '@/components/ui/Button.astro';
import { siteConfig } from '@/config';

interface Props {
  title?: string;
  subtitle?: string;
  primaryCta?: { label: string; href: string };
  secondaryCta?: { label: string; href: string };
}

const {
  title = siteConfig.name,
  subtitle = siteConfig.shortDescription,
  primaryCta = { label: 'Ver Menú', href: '/menu' },
  secondaryCta = { label: 'Contáctanos', href: '/contacto' },
} = Astro.props;
---

<section class="py-24 px-4 text-center" style="background-color: var(--color-secondary);">
  <div class="max-w-3xl mx-auto">
    <h1
      class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight mb-6"
      style="color: var(--color-primary);"
    >
      {title}
    </h1>
    <p class="text-lg sm:text-xl text-gray-600 mb-10 leading-relaxed">
      {subtitle}
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <Button href={primaryCta.href} variant="primary" size="md">
        {primaryCta.label}
      </Button>
      <Button href={secondaryCta.href} variant="outline" size="md">
        {secondaryCta.label}
      </Button>
    </div>
  </div>
</section>
