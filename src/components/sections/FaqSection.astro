---
/**
 * FaqSection — lista de preguntas frecuentes con acordeón nativo.
 *
 * Usa <details>/<summary> para interactividad sin JavaScript.
 * Soporta agrupación por categoría cuando los ítems tienen `category`.
 *
 * @prop items    - Lista de preguntas/respuestas (requerido)
 * @prop title    - Texto del encabezado de sección (opcional)
 * @prop subtitle - Texto de apoyo bajo el título (opcional)
 * @prop bg       - Fondo de sección
 * @prop size     - Padding vertical
 */
import Section from '@/components/ui/Section.astro';
import SectionHeader from '@/components/common/SectionHeader.astro';
import type { FaqItem } from '@/types';

interface Props {
  items:     FaqItem[];
  title?:    string;
  subtitle?: string;
  bg?:       'default' | 'surface' | 'secondary';
  size?:     'sm' | 'md' | 'lg';
}

const {
  items,
  title,
  subtitle,
  bg   = 'default',
  size = 'md',
} = Astro.props;

// Group items by category; items without category go under '' (rendered ungrouped).
const grouped = items.reduce<Record<string, FaqItem[]>>((acc, item) => {
  const key = item.category ?? '';
  (acc[key] ??= []).push(item);
  return acc;
}, {});

const hasGroups = Object.keys(grouped).some((k) => k !== '');
---

<Section bg={bg} size={size}>
  <div class="max-w-3xl mx-auto">

    {(title || subtitle) && (
      <SectionHeader title={title!} subtitle={subtitle} align="center" />
    )}

    <div class="space-y-10">
      {Object.entries(grouped).map(([category, groupItems]) => (
        <div>
          {hasGroups && category && (
            <h3
              class="text-xs font-semibold uppercase tracking-widest mb-4 pb-2 border-b"
              style="color: var(--color-accent); border-color: var(--color-border, #e5e7eb);"
            >
              {category}
            </h3>
          )}

          <dl class="space-y-3">
            {groupItems.map((item) => (
              <details
                class="group rounded-lg border overflow-hidden"
                style="border-color: var(--color-border, #e5e7eb); background-color: var(--color-surface);"
              >
                <summary
                  class="flex items-center justify-between gap-4 cursor-pointer select-none px-5 py-4 text-base font-medium list-none"
                  style="color: var(--color-text);"
                >
                  <dt>{item.question}</dt>
                  {/* Chevron icon — rotates when open via CSS sibling selector */}
                  <span
                    class="shrink-0 transition-transform duration-200 group-open:rotate-180"
                    aria-hidden="true"
                    style="color: var(--color-accent);"
                  >
                    <svg width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <polyline points="5 8 10 13 15 8" />
                    </svg>
                  </span>
                </summary>

                <dd
                  class="px-5 pb-5 pt-1 text-sm leading-relaxed"
                  style="color: var(--color-text-muted);"
                >
                  {item.answer}
                </dd>
              </details>
            ))}
          </dl>
        </div>
      ))}
    </div>

  </div>
</Section>
