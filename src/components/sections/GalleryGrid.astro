---
/**
 * GalleryGrid — grid responsivo de imágenes con caption opcional.
 *
 * Renderiza imágenes en un layout de columnas múltiples.
 * El `alt` es obligatorio en el tipo GalleryItem — no puede omitirse.
 *
 * @prop items   - Lista de imágenes (requerido)
 * @prop columns - Columnas máximas en pantallas grandes: 2 | 3 | 4 (default: 3)
 * @prop bg      - Fondo de sección
 * @prop size    - Padding vertical
 */
import Section from '@/components/ui/Section.astro';
import SectionHeader from '@/components/common/SectionHeader.astro';
import type { GalleryItem } from '@/types';

interface Props {
  items:     GalleryItem[];
  title?:    string;
  subtitle?: string;
  columns?:  2 | 3 | 4;
  bg?:       'default' | 'surface' | 'secondary';
  size?:     'sm' | 'md' | 'lg';
}

const {
  items,
  title,
  subtitle,
  columns = 3,
  bg      = 'default',
  size    = 'md',
} = Astro.props;

const gridClass: Record<number, string> = {
  2: 'grid-cols-1 sm:grid-cols-2',
  3: 'grid-cols-1 sm:grid-cols-2 lg:grid-cols-3',
  4: 'grid-cols-1 sm:grid-cols-2 lg:grid-cols-4',
};
---

<Section bg={bg} size={size}>
  <div class="max-w-6xl mx-auto px-4">

    {(title || subtitle) && (
      <SectionHeader title={title!} subtitle={subtitle} align="center" />
    )}

    <ul class:list={['grid gap-4', gridClass[columns]]} role="list">
      {items.map((item) => (
        <li class="overflow-hidden rounded-xl shadow-(--shadow-card) group">
          <figure class="relative h-full">
            <img
              src={item.src}
              alt={item.alt}
              loading="lazy"
              decoding="async"
              class="w-full aspect-4/3 object-cover transition-transform duration-300 group-hover:scale-105"
            />
            {item.caption && (
              <figcaption
                class="px-3 py-2 text-xs text-center leading-snug"
                style="color: var(--color-text-muted); background-color: var(--color-surface);"
              >
                {item.caption}
              </figcaption>
            )}
          </figure>
        </li>
      ))}
    </ul>

  </div>
</Section>
