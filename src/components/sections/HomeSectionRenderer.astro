---
/**
 * HomeSectionRenderer — dispatcher de secciones para la Home.
 *
 * Recibe una entrada de configuración tipada (`HomeSectionEntry`) y renderiza
 * el componente correspondiente. Toda la lógica de despacho vive aquí; las
 * páginas consumidoras sólo necesitan iterar la config e instanciar este
 * componente.
 *
 * Responsabilidades:
 *  - Importar los componentes de sección disponibles.
 *  - Inyectar runtime data (homeFeatures, openingHours) cuando proceda.
 *  - Omitir secciones no implementadas o con guardas de negocio no cumplidas.
 *
 * Para registrar una nueva sección:
 *  1. Añadir la entrada en SECTION_REGISTRY (home-section-registry.ts).
 *  2. Importar el componente aquí.
 *  3. Añadir la rama correspondiente en el bloque de renderizado.
 */
import HeroSection from './HeroSection.astro';
import FeatureSection from './FeatureSection.astro';
import OpeningHoursSection from './OpeningHoursSection.astro';
import CtaWhatsappSection from './CtaWhatsappSection.astro';

import { SECTION_REGISTRY } from './section-module-registry';
import { globalConfig } from '@/config';
import { homeFeatures } from '@/data';

import type { SectionModuleEntry } from '@/types';

interface Props {
  section: SectionModuleEntry;
}

const { section } = Astro.props;
const meta = SECTION_REGISTRY[section.id];

// Omitir secciones no implementadas sin producir errores.
const skip = !meta.implemented;
---

{!skip && section.id === 'hero' && (
  <HeroSection {...section.props} />
)}

{!skip && section.id === 'highlights' && (
  <FeatureSection {...section.props} items={homeFeatures} />
)}

{!skip && section.id === 'hours' && globalConfig.hours.length > 0 && (
  <OpeningHoursSection {...section.props} hours={globalConfig.hours} />
)}

{!skip && section.id === 'whatsapp_cta' && globalConfig.contact.whatsapp && (
  <CtaWhatsappSection {...section.props} />
)}
