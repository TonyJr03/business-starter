---
import type { ProductBadge } from '@/types';

interface Props {
  type: ProductBadge;
  class?: string;
}

const { type, class: className } = Astro.props;

const labels: Record<ProductBadge, string> = {
  new: 'Nuevo',
  popular: 'Popular',
  offer: 'Oferta',
};

const styles: Record<ProductBadge, string> = {
  new: 'bg-blue-100 text-blue-700',
  popular: 'bg-amber-100 text-amber-700',
  offer: 'bg-red-100 text-red-600',
};
---

<span
  class:list={[
    'inline-block text-xs font-semibold px-2.5 py-0.5 rounded-full',
    styles[type],
    className,
  ]}
>
  {labels[type]}
</span>
