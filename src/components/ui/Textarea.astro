---
/**
 * Textarea — área de texto multilínea con label, estados de error y texto de ayuda.
 *
 * API idéntica a Input para consistencia. Incluye resize-y por defecto
 * para que el usuario pueda expandir el campo verticalmente.
 *
 * @prop label      - Texto del label (requerido)
 * @prop id         - ID del textarea y for del label (requerido)
 * @prop name       - name del textarea (por defecto igual al id)
 * @prop placeholder - Placeholder del textarea
 * @prop required   - Marca el campo como requerido
 * @prop disabled   - Desactiva el campo
 * @prop rows       - Número de filas visibles (default: 4)
 * @prop value      - Valor inicial
 * @prop error      - Mensaje de error (aparece en rojo, activa aria-invalid)
 * @prop helperText - Texto de ayuda (solo visible si no hay error)
 * @prop class      - Clases adicionales sobre el wrapper
 */

interface Props {
  label:        string;
  id:           string;
  name?:        string;
  placeholder?: string;
  required?:    boolean;
  disabled?:    boolean;
  rows?:        number;
  value?:       string;
  error?:       string;
  helperText?:  string;
  class?:       string;
}

const {
  label,
  id,
  name,
  placeholder,
  required,
  disabled,
  rows       = 4,
  value,
  error,
  helperText,
  class: className,
} = Astro.props;

const errorId     = `${id}-error`;
const helperId    = `${id}-helper`;
const describedBy = error ? errorId : helperText ? helperId : undefined;
---

<div class:list={['flex flex-col gap-1.5', className]}>
  <label
    for={id}
    class="text-sm font-medium"
    style="color: var(--color-text);"
  >
    {label}
    {required && (
      <span aria-hidden="true" class="ml-0.5" style="color: var(--color-error);">*</span>
    )}
  </label>

  <textarea
    id={id}
    name={name ?? id}
    placeholder={placeholder}
    required={required}
    disabled={disabled}
    rows={rows}
    aria-describedby={describedBy}
    aria-invalid={error ? 'true' : undefined}
    class:list={[
      'w-full px-4 py-2.5 text-sm rounded-md',
      'border transition-colors resize-y',
      'focus:outline-none focus:ring-2 focus:ring-offset-0',
      'placeholder:text-(--color-text-subtle)',
      'disabled:opacity-50 disabled:cursor-not-allowed',
      error
        ? 'border-(--color-error)   focus:ring-(--color-error)'
        : 'border-(--color-border)  hover:border-(--color-primary) focus:ring-(--color-primary) focus:border-(--color-primary)',
    ]}
    style="background-color: var(--color-bg); color: var(--color-text);"
  >{value}</textarea>

  {error && (
    <p id={errorId} role="alert" class="text-xs" style="color: var(--color-error);">
      {error}
    </p>
  )}
  {!error && helperText && (
    <p id={helperId} class="text-xs" style="color: var(--color-text-muted);">
      {helperText}
    </p>
  )}
</div>
