---
interface Props {
  variant?:  'primary' | 'outline' | 'ghost';
  size?:     'sm' | 'md' | 'lg';
  href?:     string;
  type?:     'button' | 'submit' | 'reset';
  disabled?: boolean;
  class?:    string;
  [key: string]: unknown;
}

const {
  variant  = 'primary',
  size     = 'md',
  href,
  type     = 'button',
  disabled,
  class: className,
  ...rest
} = Astro.props;

const base = [
  'inline-flex items-center justify-center gap-2 cursor-pointer',
  'font-semibold rounded-full transition-all',
  'focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2',
  'focus-visible:ring-(--color-primary)',
  'disabled:pointer-events-none disabled:opacity-50',
].join(' ');

const variants: Record<string, string> = {
  primary: 'text-white hover:opacity-90 active:opacity-80',
  outline: [
    'border-2 bg-transparent',
    'border-(--color-primary) text-(--color-primary)',
    'hover:text-white hover:bg-(--color-primary) hover:border-(--color-primary)',
    'active:opacity-90',
  ].join(' '),
  ghost: 'bg-transparent hover:bg-(--color-secondary) active:opacity-80',
};

const sizes: Record<string, string> = {
  sm: 'px-5 py-1.5 text-sm',
  md: 'px-8 py-3 text-base',
  lg: 'px-10 py-4 text-lg',
};

const inlineStyle =
  variant === 'primary'
    ? 'background-color: var(--color-primary);'
    : variant === 'outline'
      ? 'border-color: var(--color-primary);'
      : 'color: var(--color-primary);';
---

{href ? (
  <a
    href={href}
    class:list={[base, variants[variant], sizes[size], className]}
    style={inlineStyle}
    {...rest}
  >
    <slot />
  </a>
) : (
  <button
    type={type}
    disabled={disabled}
    class:list={[base, variants[variant], sizes[size], className]}
    style={inlineStyle}
    {...rest}
  >
    <slot />
  </button>
)}
