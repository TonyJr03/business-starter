---
/**
 * ProductCard — tarjeta de producto para el catálogo / menú.
 *
 * Encapsula la presentación de un producto: nombre, descripción, precio,
 * badge, disponibilidad y acción de pedido.
 *
 * La acción de pedido se pasa como `orderHref` (enlace WhatsApp actual).
 * Cuando el módulo de carrito esté activo, el consumidor no pasará `orderHref`
 * y el slot de acción quedará vacío, listo para el botón de añadir al carrito.
 *
 * @prop product    - Objeto Product tipado.
 * @prop orderHref  - URL de acción (WhatsApp). Opcional: si no se pasa, no se muestra botón.
 */
import Card from '@/components/ui/Card.astro';
import Badge from '@/components/ui/Badge.astro';
import type { Product } from '@/types';

interface Props {
  product:    Product;
  orderHref?: string;
}

const { product, orderHref } = Astro.props;
const { name, description, money, badge, isAvailable, isFeatured } = product;

// Precio canónico: money es requerido en el tipo.
const displayPrice = `${money.amount} ${money.currency}`;
---

<Card variant={isFeatured ? 'elevated' : 'default'} class="flex flex-col h-full">
  <div class="flex flex-col gap-3 p-5 h-full">

    <!-- Nombre + badges ───────────────────────────────────────────────── -->
    <div class="flex items-start justify-between gap-3">
      <div class="flex flex-wrap items-center gap-2">
        <span
          class:list={['font-semibold leading-snug', !isAvailable && 'line-through opacity-40']}
          style="color: var(--color-text);"
        >
          {name}
        </span>
        {badge && isAvailable && <Badge variant={badge} />}
        {!isAvailable && <Badge variant="error" label="Agotado" />}
      </div>
    </div>

    <!-- Descripción ───────────────────────────────────────────────────── -->
    {description && (
      <p class="text-sm leading-relaxed flex-1" style="color: var(--color-text-muted);">
        {description}
      </p>
    )}

    <!-- Pie: precio + acción ─────────────────────────────────────────── -->
    <div class="flex items-center justify-between gap-4 pt-1 mt-auto">
      <span class="text-lg font-bold tabular-nums" style="color: var(--color-primary);">
        {displayPrice}
      </span>

      {orderHref && isAvailable && (
        <a
          href={orderHref}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 text-sm font-semibold px-4 py-1.5 rounded-full transition-colors"
          style="background-color: #25D366; color: white;"
          aria-label={`Pedir ${name} por WhatsApp`}
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="currentColor"
            class="size-4 shrink-0"
            aria-hidden="true"
          >
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
            <path d="M12 0C5.373 0 0 5.373 0 12c0 2.123.554 4.118 1.528 5.855L.057 23.428a.75.75 0 0 0 .915.915l5.573-1.471A11.943 11.943 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.75a9.693 9.693 0 0 1-4.953-1.36l-.355-.212-3.683.972.985-3.595-.231-.37A9.694 9.694 0 0 1 2.25 12C2.25 6.615 6.615 2.25 12 2.25S21.75 6.615 21.75 12 17.385 21.75 12 21.75z"/>
          </svg>
          Pedir
        </a>
      )}
    </div>

  </div>
</Card>
