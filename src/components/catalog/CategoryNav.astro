---
/**
 * CategoryNav — barra de navegación de salto entre categorías del catálogo.
 *
 * Renderiza enlaces ancla (#slug) hacia cada sección de categoría en la página.
 * Scroll horizontal en móvil. Se oculta si hay una sola categoría.
 *
 * @prop categories - Array de Category activas con su slug.
 */
import type { Category } from '@/types';

interface Props {
  categories: Category[];
}

const { categories } = Astro.props;
---

{categories.length > 1 && (
  <nav
    aria-label="Categorías del menú"
    class="sticky top-0 z-10 w-full overflow-x-auto border-b"
    style="background-color: var(--color-bg); border-color: var(--color-border);"
  >
    <ul class="flex gap-1 px-4 py-2 max-w-4xl mx-auto min-w-max sm:min-w-0 sm:flex-wrap">
      {categories.map((cat) => (
        <li>
          <a
            href={`#${cat.slug}`}
            class="inline-block px-4 py-1.5 rounded-full text-sm font-medium transition-colors whitespace-nowrap text-(--color-text-muted) hover:bg-(--color-secondary) hover:text-(--color-primary)"
          >
            {cat.name}
          </a>
        </li>
      ))}
    </ul>
  </nav>
)}
