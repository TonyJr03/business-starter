---
interface Props {
  title: string;
  subtitle?: string;
  align?: 'left' | 'center';
  class?: string;
}

const { title, subtitle, align = 'center', class: className } = Astro.props;
---

<div class:list={[align === 'center' ? 'text-center' : 'text-left', 'mb-10', className]}>
  <h2 class="text-3xl font-bold tracking-tight" style="color: var(--color-primary);">
    {title}
  </h2>
  {
    subtitle && (
      <p
        class:list={['mt-3 text-lg max-w-2xl', align === 'center' && 'mx-auto']}
        style="color: var(--color-text-muted);"
      >
        {subtitle}
      </p>
    )
  }
</div>
