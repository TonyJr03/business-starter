---
/**
 * AdminSidebar — Navegación lateral del panel administrativo.
 *
 * Recibe la ruta activa para resaltar el ítem correspondiente.
 * Los items futuros (Sprint 13+) se pueden agregar al array `navItems`.
 */

interface Props {
  rutaActual: string;
}

const { rutaActual } = Astro.props;

const navItems = [
  { href: '/admin',       label: 'Dashboard', icono: 'grid', nivel: 'principal' },
  {
    label: 'Catálogo',
    icono: 'package',
    nivel: 'principal',
    subitems: [
      { href: '/admin/catalog/categories', label: 'Categorías' },
      { href: '/admin/catalog/products',   label: 'Productos' },
    ],
  },
  { href: '/admin/promotions', label: 'Promociones', icono: 'tag', nivel: 'principal' },
  { href: '/admin/settings',   label: 'Ajustes',     icono: 'settings', nivel: 'principal' },
];

function esActivo(href?: string): boolean {
  if (!href) return false;
  // Coincidencia exacta para /admin, prefijo para subrutas.
  if (href === '/admin') return rutaActual === '/admin';
  return rutaActual.startsWith(href);
}

function esActivoGrupo(subitems: Array<{ href: string }>): boolean {
  if (!subitems) return false;
  return subitems.some(item => esActivo(item.href));
}
---

<aside class="admin-sidebar">
  <!-- Marca del panel -->
  <div class="sidebar-brand">
    <span class="brand-dot" aria-hidden="true"></span>
    <span class="brand-label">Admin</span>
  </div>

  <!-- Navegación principal -->
  <nav aria-label="Navegación admin">
    <ul class="nav-list">
      {navItems.map((item) => {
        const tieneSubitems = 'subitems' in item && item.subitems;
        const esGrupoActivo = tieneSubitems && esActivoGrupo(item.subitems);

        if (tieneSubitems) {
          // Item con subitems: grupo colapsible (siempre expandido visualmente)
          return (
            <li>
              <div class:list={['nav-group', { 'nav-group--active': esGrupoActivo }]}>
                {/* Icono + etiqueta del grupo */}
                <div class="nav-group__header">
                  {item.icono === 'package' && (
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M16.5 9.4l-9-5.19M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/>
                      <polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/>
                    </svg>
                  )}
                  <span class="nav-group__label">{item.label}</span>
                </div>
              </div>

              {/* Subitems */}
              <ul class="nav-sublist">
                {item.subitems.map(({ href, label }) => (
                  <li>
                    <a
                      href={href}
                      class:list={['nav-item nav-item--sub', { 'nav-item--active': esActivo(href) }]}
                      aria-current={esActivo(href) ? 'page' : undefined}
                    >
                      <span>{label}</span>
                    </a>
                  </li>
                ))}
              </ul>
            </li>
          );
        } else {
          // Item simple: enlace directo
          return (
            <li>
              <a
                href={item.href}
                class:list={['nav-item', { 'nav-item--active': esActivo(item.href) }]}
                aria-current={esActivo(item.href) ? 'page' : undefined}
              >
                {/* Icono SVG inline según tipo */}
                {item.icono === 'grid' && (
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/>
                    <rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/>
                  </svg>
                )}
                {item.icono === 'tag' && (
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M20.59 13.41l-7.17 7.17a2 2 0 01-2.83 0L2 12V2h10l8.59 8.59a2 2 0 010 2.82z"/>
                    <line x1="7" y1="7" x2="7.01" y2="7"/>
                  </svg>
                )}
                {item.icono === 'settings' && (
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <circle cx="12" cy="12" r="3"/><path d="M12 1v6m0 6v6M4.22 4.22l4.24 4.24m5.08 5.08l4.24 4.24M1 12h6m6 0h6M4.22 19.78l4.24-4.24m5.08-5.08l4.24-4.24"/>
                  </svg>
                )}
                <span>{item.label}</span>
              </a>
            </li>
          );
        }
      })}
    </ul>
  </nav>

  <!-- Separador + enlace al sitio público -->
  <div class="sidebar-footer">
    <a href="/" class="site-link" target="_blank" rel="noopener">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/>
        <polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>
      </svg>
      <span>Ver sitio</span>
    </a>
  </div>
</aside>

<style>
  .admin-sidebar {
    display: flex;
    flex-direction: column;
    width: 220px;
    min-height: 100vh;
    background: #111827;
    color: #D1D5DB;
    flex-shrink: 0;
  }

  .sidebar-brand {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    padding: 1.5rem 1.25rem 1.25rem;
    border-bottom: 1px solid #1F2937;
    font-weight: 700;
    font-size: 0.9375rem;
    color: #F9FAFB;
    letter-spacing: 0.02em;
  }

  .brand-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #6F4E37;
    flex-shrink: 0;
  }

  .nav-list {
    list-style: none;
    padding: 1rem 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    flex: 1;
  }

  /* ── Grupo de navegación (con subitems) ──────────────────────────── */
  .nav-group {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.5rem 0.75rem;
    border-radius: 6px;
    font-size: 0.875rem;
    font-weight: 500;
    color: #9CA3AF;
    transition: background 0.15s, color 0.15s;
  }

  .nav-group:hover {
    background: #1F2937;
    color: #F9FAFB;
  }

  .nav-group--active {
    background: #1F2937;
    color: #F9FAFB;
  }

  .nav-group--active svg {
    color: #D4A574;
  }

  .nav-group__header {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    width: 100%;
  }

  .nav-group__label { flex: 1; }

  /* ── Subitems ───────────────────────────────────────────────────── */
  .nav-sublist {
    list-style: none;
    padding: 0.25rem 0 0.25rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  /* ── Item individual ────────────────────────────────────────────── */
  .nav-item {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.5rem 0.75rem;
    border-radius: 6px;
    font-size: 0.875rem;
    font-weight: 500;
    color: #9CA3AF;
    text-decoration: none;
    transition: background 0.15s, color 0.15s;
  }

  .nav-item:hover {
    background: #1F2937;
    color: #F9FAFB;
  }

  .nav-item--active {
    background: #1F2937;
    color: #F9FAFB;
  }

  .nav-item--active svg {
    color: #D4A574;
  }

  /* ── Subitem (indentado bajo grupo) ─────────────────────────────── */
  .nav-item--sub {
    padding: 0.375rem 0.625rem;
    font-size: 0.8125rem;
    color: #9CA3AF;
    position: relative;
    padding-left: 1rem;
  }

  .nav-item--sub::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: #6B7280;
    transition: background 0.15s;
  }

  .nav-item--sub:hover {
    background: #1F2937;
    color: #E5E7EB;
  }

  .nav-item--sub:hover::before {
    background: #D1D5DB;
  }

  .nav-item--sub.nav-item--active {
    background: transparent;
    color: #F9FAFB;
  }

  .nav-item--sub.nav-item--active::before {
    background: #D4A574;
  }

  .sidebar-footer {
    padding: 1rem 0.75rem 1.25rem;
    border-top: 1px solid #1F2937;
  }

  .site-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    color: #6B7280;
    text-decoration: none;
    padding: 0.375rem 0.5rem;
    border-radius: 4px;
    transition: color 0.15s;
  }

  .site-link:hover { color: #9CA3AF; }
</style>
